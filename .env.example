# Supabase — Dashboard → Settings → API Keys → Publishable key (sb_publishable_...) or legacy anon JWT (eyJ...)
# After changing .env: restart the dev server (npm run dev). For production builds, env vars must exist at build time.
# Run supabase-schema.sql in the Supabase SQL Editor before syncing.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# Google OAuth (optional)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_AUTH_REDIRECT_URL=http://localhost:5177/dashboard

# Dev server
VITE_DEV_SERVER_PORT=5177
VITE_DEV_HMR_CLIENT_PORT=5177

# Observability (optional)
VITE_SENTRY_DSN=

# Offline read-only cache access (disabled by default)
VITE_ENABLE_OFFLINE_READONLY=false
# Public SPKI key for verifying offline ES256 grants in the browser.
VITE_OFFLINE_PUBLIC_KEY=

# Web Push VAPID public key (base64url). Required for background push notifications.
VITE_VAPID_PUBLIC_KEY=

# Server-only Supabase Edge Function secrets (do not expose with VITE_)
OFFLINE_READONLY_ENABLED=false
OFFLINE_SIGNING_KEY=
CLEANUP_CRON_KEY=
# VAPID key pair for Web Push (server-only).
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
